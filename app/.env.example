# RPC endpoint for the frontend.
# Public devnet (https://api.devnet.solana.com) rate-limits aggressively and will
# 429 frequently. Use a free Helius / QuickNode / Triton devnet endpoint for a
# smooth demo. Format:
# VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY_HERE

VITE_RPC_URL=https://api.devnet.solana.com
