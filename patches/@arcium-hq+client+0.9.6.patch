+    // PATCHED skip-on-size unsafe (partial uploads pass with zero data)
+    if (false && existingAcc !== null && existingAcc.data.length >= requiredAccountSize) {
         optionalLog(shouldLog, `Raw circuit acc ${rawCircuitIndex} already exists with sufficient size, skipping`);
         return [];
     }
